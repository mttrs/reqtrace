{
  "name": "Request trace",
  "repository": "https://github.com/mttrs/reqtrace",
  "addons": [
    {
      "plan": "papertrail:choklad"
    }
  ],
  "buildpacks": [
    { "url": "heroku/go" }
  ],
  "environments": {
    "test": {
      "addons": ["heroku-postgresql:in-dyno"],
      "scripts": {
	"test-setup": "psql $DATABASE_URL -c 'ALTER SYSTEM SET max_connections=500;' && pg_ctl restart && exit 1",
	"test": "go test"
      }
    }
  }
}
